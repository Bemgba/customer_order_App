# ---------------------------------------------------------------------------
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ---------------------------------------------------------------------------

# Django core
SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=True
# For Render deployment use: ALLOWED_HOSTS=your-app-name.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Django settings module
# Local dev:  crm1.settings.dev
# Production: crm1.settings.prod
DJANGO_SETTINGS_MODULE=crm1.settings.dev

# ---------------------------------------------------------------------------
# Branding — change these for each client deployment
# ---------------------------------------------------------------------------
COMPANY_NAME=Your Company Name Here
COMPANY_SHORT_NAME=CompanyShort
COMPANY_TAGLINE=Your tagline here.

# ---------------------------------------------------------------------------
# PostgreSQL database
# DB_USER is 'postgres' by default on a fresh PostgreSQL install (not 'root')
# On Render: leave DB_* vars blank — use DATABASE_URL instead (auto-provided)
# ---------------------------------------------------------------------------
# DATABASE_URL=postgres://user:password@host:5432/dbname   ← Render sets this
DB_NAME=foodvendordb
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=5432

# ---------------------------------------------------------------------------
# Email — SMTP
# Port 465 → EMAIL_USE_SSL=True,  EMAIL_USE_TLS=False
# Port 587 → EMAIL_USE_TLS=True,  EMAIL_USE_SSL=False
# ---------------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_FROM=YourApp <your-email@gmail.com>
